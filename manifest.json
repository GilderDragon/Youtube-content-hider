{
  "manifest_version": 3,
  "name": "YouTube Content Blocker",
  "version": "1.0",
  "description": "Replaces clickbait previews and blocks spoilers by keywords",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
	  "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["resources/blocked.png"],
      "matches": ["*://*.youtube.com/*"]
    }
  ],
  "icons": {
    "128": "resources/icon.png"
  }
}
